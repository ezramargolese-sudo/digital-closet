# Copy this file to `.env.local` and fill in the values from your Supabase project.
# Supabase dashboard → Project Settings → API.

# Public — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# SECRET — server only. Bypasses Row Level Security. NEVER commit. NEVER expose to browser.
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role_key_here...
